# Gmail
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
GMAIL_QUERY=subject:("offering memorandum" OR "OM") has:attachment filename:pdf
GMAIL_POLL_MINUTES=5

# Model provider: gemini|regex
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OCR
OCR_ENABLED=true

# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#deal-intake

# Storage
DATA_DIR=./data
DATABASE_URL=sqlite:///./data/deals.db
